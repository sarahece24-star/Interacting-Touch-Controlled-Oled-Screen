void resetCactus(int i) {
  cactusX[i] = 128 + random(30, 80);
  cactusH[i] = random(12, 20);
  cactusW[i] = random(8, 14);
}

bool checkCollision(int i) {
  int dLeft  = DINO_X;
  int dRight = DINO_X + DINO_W - 1;
  int dTop   = dinoY;
  int dBot   = dinoY + DINO_H - 1;

  int cLeft  = cactusX[i];
  int cRight = cactusX[i] + cactusW[i] - 1;
  int cTop   = GROUND_Y - cactusH[i];
  int cBot   = GROUND_Y;

  // Shrink hitbox slightly for fairness
  return (dRight - 2 > cLeft + 1) &&
         (dLeft  + 2 < cRight - 1) &&
         (dBot   - 2 > cTop) &&
         (dTop       < cBot);
}

