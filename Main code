bool buttonPressed(int pin) {
  if (digitalRead(pin) == LOW) {
    if (millis() - lastDebounce > DEBOUNCE_DELAY) {
      lastDebounce = millis();
      return true;
    }
  }
  return false;
}

// Raw button read for jump (no debounce delay needed mid-game)
bool buttonDown(int pin) {
  return digitalRead(pin) == LOW;
}

