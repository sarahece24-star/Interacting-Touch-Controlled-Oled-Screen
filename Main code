#define SNAKE_BLK  4
#define SNAKE_OX  18
#define SNAKE_OY   4
#define SNAKE_MAX 24   // was 60 — saves 144 bytes

int8_t snakeX[SNAKE_MAX], snakeY[SNAKE_MAX];  // int8_t not int — saves 48 bytes
int  snakeLen,snakeDirX,snakeDirY,foodX,foodY,snakeScore;
bool snakeOver,snakeStarted;
unsigned long lastSnakeTick;

void placeFood(){bool ok=false;while(!ok){foodX=random(SNAKE_W);foodY=random(SNAKE_H);ok=true;for(int i=0;i<snakeLen;i++)if(snakeX[i]==foodX&&snakeY[i]==foodY){ok=false;break;}}}
void initSnake(){snakeLen=3;snakeX[0]=10;snakeY[0]=6;snakeX[1]=9;snakeY[1]=6;snakeX[2]=8;snakeY[2]=6;snakeDirX=1;snakeDirY=0;snakeScore=0;snakeOver=false;snakeStarted=false;placeFood();lastSnakeTick=millis();}

void showSnakeStart(){display.clearDisplay();display.setTextColor(SH110X_WHITE);display.setTextSize(1);display.setCursor(38,2);display.print(F("SNAKE"));display.setCursor(4,16);display.print(F("UP=up  DOWN=down"));display.setCursor(4,28);display.print(F("SEL=right"));display.setCursor(4,40);display.print(F("WAKE=left (in-game)"));display.setCursor(4,54);display.print(F("Press UP to start"));display.display();}
void showSnakeOver(){display.clearDisplay();display.setTextColor(SH110X_WHITE);display.setTextSize(1);display.setCursor(22,10);display.print(F("GAME OVER"));display.setCursor(14,26);display.print(F("Score:"));display.print(snakeScore);display.setCursor(8,42);display.print(F("UP=retry WAKE=menu"));display.display();}

void drawSnake(){
  display.clearDisplay();
  display.drawRect(SNAKE_OX-1,SNAKE_OY-1,SNAKE_W*SNAKE_BLK+2,SNAKE_H*SNAKE_BLK+2,SH110X_WHITE);
  for(int i=0;i<snakeLen;i++)display.fillRect(SNAKE_OX+snakeX[i]*SNAKE_BLK,SNAKE_OY+snakeY[i]*SNAKE_BLK,SNAKE_BLK-1,SNAKE_BLK-1,SH110X_WHITE);
  display.fillRect(SNAKE_OX+foodX*SNAKE_BLK+1,SNAKE_OY+foodY*SNAKE_BLK+1,SNAKE_BLK-3,SNAKE_BLK-3,SH110X_WHITE);
  display.setTextColor(SH110X_WHITE);display.setTextSize(1);display.setCursor(0,0);display.print(F("S:"));display.print(snakeScore);
  display.display();
}

void runSnake(){
  // direction — WAKE used as left only during gameplay
  if(buttonDown(BTN_UP)&&snakeDirY!=1){snakeDirX=0;snakeDirY=-1;}
  else if(buttonDown(BTN_DOWN)&&snakeDirY!=-1){snakeDirX=0;snakeDirY=1;}
  else if(buttonDown(BTN_SELECT)&&snakeDirX!=-1){snakeDirX=1;snakeDirY=0;}
  else if(buttonDown(BTN_WAKE)&&snakeDirX!=1){snakeDirX=-1;snakeDirY=0;lastDebounce=millis();}
  if(millis()-lastSnakeTick<200)return;lastSnakeTick=millis();
  int nx=snakeX[0]+snakeDirX,ny=snakeY[0]+snakeDirY;
  if(nx<0||nx>=SNAKE_W||ny<0||ny>=SNAKE_H){snakeOver=true;showSnakeOver();return;}
  for(int i=0;i<snakeLen-1;i++)if(snakeX[i]==nx&&snakeY[i]==ny){snakeOver=true;showSnakeOver();return;}
  bool ate=(nx==foodX&&ny==foodY);
  for(int i=min(snakeLen-1+(ate?1:0),SNAKE_MAX-1);i>0;i--){snakeX[i]=snakeX[i-1];snakeY[i]=snakeY[i-1];}
  snakeX[0]=nx;snakeY[0]=ny;
  if(ate){if(snakeLen<SNAKE_MAX)snakeLen++;snakeScore++;placeFood();}
  drawSnake();
}

// ══════════════════════════════════════════
//  GAME 5 — BREAKOUT
// ══════════════════════════════════════════
#define BRK_ROWS 4
#define BRK_COLS 8
#define BRK_BW   14
#define BRK_BH    4
#define BRK_PW   24

int  padX,ballX,ballY,ballVX,ballVY,brkScore,brkLives;
bool bricks[BRK_ROWS][BRK_COLS];
bool brkOver,brkWon,brkStarted;
unsigned long lastBrkTick;

void initBreakout(){padX=52;ballX=64;ballY=50;ballVX=2;ballVY=-2;for(int r=0;r<BRK_ROWS;r++)for(int c=0;c<BRK_COLS;c++)bricks[r][c]=true;brkScore=0;brkLives=3;brkOver=false;brkWon=false;brkStarted=false;lastBrkTick=millis();}

void showBrkStart(){display.clearDisplay();display.setTextColor(SH110X_WHITE);display.setTextSize(1);display.setCursor(26,8);display.print(F("BREAKOUT"));display.setCursor(4,22);display.print(F("DOWN   = paddle left"));display.setCursor(4,34);display.print(F("SELECT = paddle right"));display.setCursor(4,48);display.print(F("Press SELECT to start"));display.display();}
void showBrkEnd(bool w){display.clearDisplay();display.setTextColor(SH110X_WHITE);display.setTextSize(1);display.setCursor(w?26:22,10);display.print(w?F("YOU WIN!"):F("GAME OVER"));display.setCursor(14,28);display.print(F("Score:"));display.print(brkScore);display.setCursor(8,44);display.print(F("SEL=restart WAKE=menu"));display.display();}

void drawBreakout(){
  display.clearDisplay();
  for(int r=0;r<BRK_ROWS;r++)for(int c=0;c<BRK_COLS;c++)if(bricks[r][c])display.fillRect(c*BRK_BW,2+r*(BRK_BH+2),BRK_BW-1,BRK_BH,SH110X_WHITE);
  display.fillRect(padX,61,BRK_PW,3,SH110X_WHITE);
  display.fillCircle(ballX,ballY,3,SH110X_WHITE);
  display.setTextColor(SH110X_WHITE);display.setTextSize(1);
  display.setCursor(0,56);display.print(F("L:"));display.print(brkLives);
  display.setCursor(90,56);display.print(F("S:"));display.print(brkScore);
  display.display();
}

void runBreakout(){
  if(millis()-lastBrkTick<30)return;lastBrkTick=millis();
  if(buttonDown(BTN_DOWN)&&padX>0)padX-=4;
  if(buttonDown(BTN_SELECT)&&padX<128-BRK_PW)padX+=4;
  ballX+=ballVX;ballY+=ballVY;
  if(ballX<=3){ballX=3;ballVX=abs(ballVX);}
  if(ballX>=124){ballX=124;ballVX=-abs(ballVX);}
  if(ballY<=3){ballY=3;ballVY=abs(ballVY);}
  if(ballY>=61&&ballX>=padX&&ballX<=padX+BRK_PW){ballVY=-abs(ballVY);int off=ballX-(padX+BRK_PW/2);ballVX=off/(BRK_PW/4);if(ballVX==0)ballVX=1;}
  if(ballY>66){brkLives--;if(brkLives<=0){brkOver=true;showBrkEnd(false);return;}ballX=padX+BRK_PW/2;ballY=50;ballVX=2;ballVY=-2;}
  int bc=ballX/BRK_BW,br=(ballY-2)/(BRK_BH+2);
  if(br>=0&&br<BRK_ROWS&&bc>=0&&bc<BRK_COLS&&bricks[br][bc]){bricks[br][bc]=false;ballVY=-ballVY;brkScore++;bool any=false;for(int r=0;r<BRK_ROWS;r++)for(int c=0;c<BRK_COLS;c++)if(bricks[r][c]){any=true;break;}if(!any){brkWon=true;showBrkEnd(true);return;}}
  drawBreakout();
}

// ══════════════════════════════════════════
//  goToOption
// ══════════════════════════════════════════
void goToOption(int i){
  switch(i){
    case 0:currentState=STATE_DINO;    initDino();     showDinoStart();   break;
    case 1:currentState=STATE_TETRIS;  initTetris();   showTetStart();    break;
    case 2:currentState=STATE_FLAPPY;  initFlappy();   showFlappyStart(); break;
    case 3:currentState=STATE_SNAKE;   initSnake();    showSnakeStart();  break;
    case 4:currentState=STATE_BREAKOUT;initBreakout(); showBrkStart();    break;
    case 5:currentState=STATE_CAT;catFrame=0;lastFrameTime=millis();showCat();break;
  }
}

// ══════════════════════════════════════════
//  SETUP & LOOP
// ══════════════════════════════════════════
void setup(){
  pinMode(BTN_WAKE,INPUT_PULLUP);pinMode(BTN_UP,INPUT_PULLUP);
  pinMode(BTN_DOWN,INPUT_PULLUP);pinMode(BTN_SELECT,INPUT_PULLUP);
  randomSeed(analogRead(0));
  display.begin(0x3C,true);
  display.clearDisplay();display.display();
}

void loop(){
  if(!screenOn&&buttonPressed(BTN_WAKE)){screenOn=true;currentState=STATE_CAT;catFrame=0;lastFrameTime=millis();showCat();}
  if(!screenOn)return;

  if(currentState==STATE_CAT){
    if(millis()-lastFrameTime>300){catFrame=1-catFrame;lastFrameTime=millis();showCat();}
    if(buttonPressed(BTN_SELECT)){currentState=STATE_MENU;selectedIndex=0;showMenu();}
    if(buttonPressed(BTN_WAKE)){screenOn=false;display.clearDisplay();display.display();}
  }

  else if(currentState==STATE_MENU){
    if(buttonPressed(BTN_UP)){selectedIndex=(selectedIndex-1+menuCount)%menuCount;showMenu();}
    if(buttonPressed(BTN_DOWN)){selectedIndex=(selectedIndex+1)%menuCount;showMenu();}
    if(buttonPressed(BTN_SELECT))goToOption(selectedIndex);
    if(buttonPressed(BTN_WAKE)){currentState=STATE_CAT;catFrame=0;lastFrameTime=millis();showCat();}
  }

  else if(currentState==STATE_DINO){
    if(!dinoStarted){if(buttonPressed(BTN_SELECT)){dinoStarted=true;lastDebounce=millis()+300;}if(buttonPressed(BTN_WAKE)){backToMenu();showMenu();}}
    else if(dinoOver){if(buttonPressed(BTN_SELECT)){initDino();dinoStarted=true;lastDebounce=millis()+300;}if(buttonPressed(BTN_WAKE)){backToMenu();showMenu();}}
    else{runDino();if(buttonPressed(BTN_WAKE)){backToMenu();showMenu();}}
  }

  else if(currentState==STATE_TETRIS){
    if(!tetStarted){if(buttonDown(BTN_UP)&&millis()-lastDebounce>400){lastDebounce=millis();tetStarted=true;lastTetFall=millis();lastTetInput=millis();drawTetris();}if(buttonPressed(BTN_WAKE)){backToMenu();showMenu();}}
    else if(tetOver){if(buttonDown(BTN_UP)&&millis()-lastDebounce>500){lastDebounce=millis();initTetris();tetStarted=true;lastTetFall=millis();drawTetris();}if(buttonPressed(BTN_WAKE)){backToMenu();showMenu();}}
    else{runTetris();if(buttonPressed(BTN_WAKE)){backToMenu();showMenu();}}
  }

  else if(currentState==STATE_FLAPPY){
    if(!flappyStarted){if(buttonPressed(BTN_SELECT)){flappyStarted=true;lastDebounce=millis()+300;}if(buttonPressed(BTN_WAKE)){backToMenu();showMenu();}}
    else if(flappyOver){if(buttonPressed(BTN_SELECT)){initFlappy();flappyStarted=true;lastDebounce=millis()+300;}if(buttonPressed(BTN_WAKE)){backToMenu();showMenu();}}
    else{runFlappy();if(buttonPressed(BTN_WAKE)){backToMenu();showMenu();}}
  }

  else if(currentState==STATE_SNAKE){
    if(!snakeStarted){if(buttonDown(BTN_UP)&&millis()-lastDebounce>400){lastDebounce=millis();snakeStarted=true;lastSnakeTick=millis();drawSnake();}if(buttonPressed(BTN_WAKE)){backToMenu();showMenu();}}
    else if(snakeOver){if(buttonDown(BTN_UP)&&millis()-lastDebounce>500){lastDebounce=millis();initSnake();snakeStarted=true;lastSnakeTick=millis();drawSnake();}if(buttonPressed(BTN_WAKE)){backToMenu();showMenu();}}
    else{runSnake();if(snakeDirX!=-1&&buttonPressed(BTN_WAKE)){backToMenu();showMenu();}}
  }

  else if(currentState==STATE_BREAKOUT){
    if(!brkStarted){if(buttonPressed(BTN_SELECT)){brkStarted=true;lastDebounce=millis()+300;}if(buttonPressed(BTN_WAKE)){backToMenu();showMenu();}}
    else if(brkOver||brkWon){if(buttonPressed(BTN_SELECT)){initBreakout();brkStarted=true;lastDebounce=millis()+300;}if(buttonPressed(BTN_WAKE)){backToMenu();showMenu();}}
    else{runBreakout();if(buttonPressed(BTN_WAKE)){backToMenu();showMenu();}}
  }
}
