//  GAME 1 — DINO
// ══════════════════════════════════════════
#define GROUND_Y 54
#define DINO_X   16
#define DINO_W   12
#define DINO_H   14

int  dinoY, dinoVY;
int  cactusX[2], cactusH[2], cactusW[2];
int  dinoScore, dinoSpeed;
bool dinoOnGround, dinoLegToggle, dinoOver, dinoStarted;
unsigned long lastDinoTick, lastLegToggle;

void drawDino(int y, bool leg) {
  display.fillRect(DINO_X,   y,      DINO_W,  DINO_H-4,SH110X_WHITE);
  display.fillRect(DINO_X+4, y-4,    8,       6,       SH110X_WHITE);
  display.fillRect(DINO_X+9, y-3,    2,       2,       SH110X_BLACK);
  display.fillRect(DINO_X-3, y+2,    4,       4,       SH110X_WHITE);
  if (leg) { display.fillRect(DINO_X+2,y+DINO_H-4,3,4,SH110X_WHITE); display.fillRect(DINO_X+7,y+DINO_H-6,3,2,SH110X_WHITE); }
  else      { display.fillRect(DINO_X+2,y+DINO_H-6,3,2,SH110X_WHITE); display.fillRect(DINO_X+7,y+DINO_H-4,3,4,SH110X_WHITE); }
}

void drawCactus(int x,int h,int w) {
  display.fillRect(x+w/2-2,GROUND_Y-h,4,h,SH110X_WHITE);
  display.fillRect(x,GROUND_Y-h+6,w/2-1,3,SH110X_WHITE);
  display.fillRect(x,GROUND_Y-h+2,3,6,SH110X_WHITE);
  display.fillRect(x+w/2+2,GROUND_Y-h+6,w/2-1,3,SH110X_WHITE);
  display.fillRect(x+w-3,GROUND_Y-h+2,3,6,SH110X_WHITE);
}

void resetCactus(int i) { cactusX[i]=128+random(30,80); cactusH[i]=random(12,20); cactusW[i]=random(8,14); }
bool dinoHit(int i) { return (DINO_X+DINO_W-2>cactusX[i]+1)&&(DINO_X+2<cactusX[i]+cactusW[i]-1)&&(dinoY+DINO_H-2>GROUND_Y-cactusH[i])&&(dinoY<GROUND_Y); }

void initDino() {
  dinoY=GROUND_Y-DINO_H; dinoVY=0; dinoOnGround=true; dinoLegToggle=false;
  dinoScore=0; dinoSpeed=2; dinoOver=false; dinoStarted=false;
  lastDinoTick=millis(); lastLegToggle=millis();
  cactusX[0]=140;cactusH[0]=14;cactusW[0]=10;
  cactusX[1]=220;cactusH[1]=18;cactusW[1]=12;
}

void showDinoStart() {
  display.clearDisplay();
  display.drawLine(0,GROUND_Y,128,GROUND_Y,SH110X_WHITE);
  drawDino(dinoY,false);
  display.setTextColor(SH110X_WHITE);display.setTextSize(1);
  display.setCursor(34,10);display.print(F("DINO GAME"));
  display.setCursor(10,26);display.print(F("UP/SEL = jump"));
  display.setCursor(10,40);display.print(F("Press SELECT"));
  display.display();
}

void showDinoOver() {
  display.clearDisplay();
  display.setTextColor(SH110X_WHITE);display.setTextSize(1);
  display.setCursor(22,10);display.print(F("GAME OVER"));
  display.setCursor(14,26);display.print(F("Score:"));display.print(dinoScore);
  display.setCursor(8,42);display.print(F("SEL=restart WAKE=menu"));
  display.display();
}

void runDino() {
  if (millis()-lastDinoTick<40) return;
  lastDinoTick=millis();
  if ((buttonDown(BTN_UP)||buttonDown(BTN_SELECT))&&dinoOnGround){dinoVY=-10;dinoOnGround=false;lastDebounce=millis();}
  dinoVY++;dinoY+=dinoVY;
  if (dinoY>=GROUND_Y-DINO_H){dinoY=GROUND_Y-DINO_H;dinoVY=0;dinoOnGround=true;}
  for (int i=0;i<2;i++){
    cactusX[i]-=dinoSpeed;
    if (cactusX[i]+cactusW[i]<0){resetCactus(i);dinoScore++;if(dinoScore%5==0&&dinoSpeed<6)dinoSpeed++;}
    if (dinoHit(i)){dinoOver=true;showDinoOver();return;}
  }
  if (dinoOnGround&&millis()-lastLegToggle>120){dinoLegToggle=!dinoLegToggle;lastLegToggle=millis();}
  display.clearDisplay();
  display.drawLine(0,GROUND_Y,128,GROUND_Y,SH110X_WHITE);
  display.setTextColor(SH110X_WHITE);display.setTextSize(1);
  display.setCursor(80,2);display.print(F("SC:"));display.print(dinoScore);
  drawDino(dinoY,dinoOnGround?dinoLegToggle:false);
  for (int i=0;i<2;i++) if(cactusX[i]<128) drawCactus(cactusX[i],cactusH[i],cactusW[i]);
  display.display();
}

// ══════════════════════════════════════════
//  GAME 2 — TETRIS
// ══════════════════════════════════════════
#define TET_W 8
#define TET_H 14
#define TET_BLK 4
#define TET_BX 32
#define TET_BY 2

uint8_t tetBoard[TET_H];
const int8_t PIECES[7][4][2] PROGMEM = {
  {{0,0},{0,1},{0,2},{0,3}},{{0,0},{0,1},{1,0},{1,1}},
  {{0,1},{1,0},{1,1},{1,2}},{{0,0},{1,0},{1,1},{1,2}},
  {{0,2},{1,0},{1,1},{1,2}},{{0,0},{0,1},{1,1},{1,2}},
  {{0,1},{0,2},{1,0},{1,1}},
};
int8_t tetPiece[4][2];
int tetPR,tetPC,tetNextType,tetScore,tetLines,tetLevel;
bool tetOver,tetStarted;
unsigned long lastTetFall,lastTetInput;

bool tetGet(int r,int c){if(c<0||c>=TET_W||r>=TET_H)return true;if(r<0)return false;return(tetBoard[r]>>(7-c))&1;}
void tetSet(int r,int c){if(r>=0&&r<TET_H&&c>=0&&c<TET_W)tetBoard[r]|=(1<<(7-c));}
bool tetValid(int8_t b[4][2],int pr,int pc){for(int i=0;i<4;i++){if(tetGet(b[i][0]+pr,b[i][1]+pc))return false;}return true;}
void tetSpawn(int t){tetPR=0;tetPC=2;for(int i=0;i<4;i++){tetPiece[i][0]=(int8_t)pgm_read_byte(&PIECES[t][i][0]);tetPiece[i][1]=(int8_t)pgm_read_byte(&PIECES[t][i][1]);}}
void tetRotate(){int8_t r[4][2];int8_t n=127,x=127,m=-128,y=-128;for(int i=0;i<4;i++){n=min(n,tetPiece[i][0]);x=min(x,tetPiece[i][1]);m=max(m,tetPiece[i][0]);y=max(y,tetPiece[i][1]);}int s=max(m-n,y-x)+1;for(int i=0;i<4;i++){r[i][0]=tetPiece[i][1]-x;r[i][1]=s-1-(tetPiece[i][0]-n);}if(tetValid(r,tetPR,tetPC))memcpy(tetPiece,r,sizeof(tetPiece));}
void tetLock(){for(int i=0;i<4;i++)tetSet(tetPiece[i][0]+tetPR,tetPiece[i][1]+tetPC);int cl=0;for(int r=TET_H-1;r>=0;r--){if(tetBoard[r]==0xFF){cl++;for(int rr=r;rr>0;rr--)tetBoard[rr]=tetBoard[rr-1];tetBoard[0]=0;r++;}}if(cl){int p[]={0,40,100,300,1200};tetScore+=p[cl]*(tetLevel+1);tetLines+=cl;tetLevel=tetLines/10;}tetSpawn(tetNextType);tetNextType=random(7);if(!tetValid(tetPiece,tetPR,tetPC))tetOver=true;lastTetFall=millis();}

void drawTetris(){
  display.clearDisplay();
  display.drawRect(TET_BX-1,TET_BY,TET_W*TET_BLK+2,TET_H*TET_BLK+1,SH110X_WHITE);
  for(int r=0;r<TET_H;r++)for(int c=0;c<TET_W;c++)if((tetBoard[r]>>(7-c))&1)display.fillRect(TET_BX+c*TET_BLK,TET_BY+r*TET_BLK,TET_BLK-1,TET_BLK-1,SH110X_WHITE);
  for(int i=0;i<4;i++){int r=tetPiece[i][0]+tetPR,c=tetPiece[i][1]+tetPC;if(r>=0)display.fillRect(TET_BX+c*TET_BLK,TET_BY+r*TET_BLK,TET_BLK-1,TET_BLK-1,SH110X_WHITE);}
  display.setTextColor(SH110X_WHITE);display.setTextSize(1);
  display.setCursor(2,4);display.print(F("SC"));display.setCursor(2,14);display.print(tetScore);
  display.setCursor(2,30);display.print(F("LV"));display.setCursor(2,40);display.print(tetLevel);
  display.display();
}

void showTetStart(){display.clearDisplay();display.setTextColor(SH110X_WHITE);display.setTextSize(1);display.setCursor(34,2);display.print(F("TETRIS"));display.setCursor(4,16);display.print(F("UP=rotate"));display.setCursor(4,28);display.print(F("DWN=left SEL=right"));display.setCursor(4,44);display.print(F("Press UP to start"));display.display();}
void showTetOver(){display.clearDisplay();display.setTextColor(SH110X_WHITE);display.setTextSize(1);display.setCursor(22,10);display.print(F("GAME OVER"));display.setCursor(14,26);display.print(F("Score:"));display.print(tetScore);display.setCursor(4,44);display.print(F("UP=retry WAKE=menu"));display.display();}

void initTetris(){memset(tetBoard,0,sizeof(tetBoard));tetScore=0;tetLines=0;tetLevel=0;tetOver=false;tetStarted=false;tetNextType=random(7);tetSpawn(random(7));lastTetFall=millis();lastTetInput=millis();}
int tetSpd(){return max(150,600-tetLevel*60);}
void runTetris(){unsigned long n=millis();if(n-lastTetInput>160){bool m=false;if(buttonDown(BTN_DOWN)){if(tetValid(tetPiece,tetPR,tetPC-1))tetPC--;m=true;}else if(buttonDown(BTN_SELECT)){if(tetValid(tetPiece,tetPR,tetPC+1))tetPC++;m=true;}else if(buttonDown(BTN_UP)){tetRotate();m=true;}if(m){lastTetInput=n;drawTetris();return;}}if(n-lastTetFall>(unsigned long)tetSpd()){if(tetValid(tetPiece,tetPR+1,tetPC))tetPR++;else{tetLock();if(tetOver){showTetOver();return;}}lastTetFall=n;drawTetris();}}

// ══════════════════════════════════════════
//  GAME 3 — FLAPPY BIRD
// ══════════════════════════════════════════
#define BIRD_X   20
#define BIRD_R    4
#define PIPE_W    8
#define PIPE_GAP 28

int  birdY,birdVY;
int  pipeX[2],pipeGapY[2];
int  flappyScore;
bool flappyOver,flappyStarted;
unsigned long lastFlappyTick;

void initFlappy(){birdY=32;birdVY=0;pipeX[0]=110;pipeGapY[0]=8+random(14);pipeX[1]=174;pipeGapY[1]=8+random(14);flappyScore=0;flappyOver=false;flappyStarted=false;lastFlappyTick=millis();}

void drawPipe(int x,int g){if(x<-PIPE_W||x>128)return;display.fillRect(x,0,PIPE_W,g,SH110X_WHITE);display.fillRect(x,g+PIPE_GAP,PIPE_W,64-(g+PIPE_GAP),SH110X_WHITE);display.fillRect(x-1,g-3,PIPE_W+2,4,SH110X_WHITE);display.fillRect(x-1,g+PIPE_GAP-1,PIPE_W+2,4,SH110X_WHITE);}
bool flappyHit(int i){return(BIRD_X+BIRD_R>pipeX[i])&&(BIRD_X-BIRD_R<pipeX[i]+PIPE_W)&&(birdY-BIRD_R<pipeGapY[i]||birdY+BIRD_R>pipeGapY[i]+PIPE_GAP);}

void showFlappyStart(){display.clearDisplay();display.setTextColor(SH110X_WHITE);display.setTextSize(1);display.setCursor(22,8);display.print(F("FLAPPY BIRD"));display.fillCircle(BIRD_X,32,BIRD_R,SH110X_WHITE);display.setCursor(6,26);display.print(F("SEL/UP = flap"));display.setCursor(6,40);display.print(F("Press SELECT"));display.display();}
void showFlappyOver(){display.clearDisplay();display.setTextColor(SH110X_WHITE);display.setTextSize(1);display.setCursor(22,10);display.print(F("GAME OVER"));display.setCursor(14,26);display.print(F("Score:"));display.print(flappyScore);display.setCursor(8,42);display.print(F("SEL=restart WAKE=menu"));display.display();}

void runFlappy(){
  if(millis()-lastFlappyTick<35)return;lastFlappyTick=millis();
  if(buttonDown(BTN_SELECT)||buttonDown(BTN_UP)){birdVY=-3;lastDebounce=millis();}
  birdVY++;birdY+=birdVY;
  if(birdY-BIRD_R<=0)birdY=BIRD_R;
  if(birdY+BIRD_R>=63){flappyOver=true;showFlappyOver();return;}
  for(int i=0;i<2;i++){pipeX[i]-=2;if(pipeX[i]+PIPE_W<0){pipeX[i]=128+random(10,30);pipeGapY[i]=8+random(14);flappyScore++;}if(flappyHit(i)){flappyOver=true;showFlappyOver();return;}}
  display.clearDisplay();for(int i=0;i<2;i++)drawPipe(pipeX[i],pipeGapY[i]);
  display.fillCircle(BIRD_X,birdY,BIRD_R,SH110X_WHITE);
  display.drawPixel(BIRD_X+2,birdY-1,SH110X_BLACK);
  display.setTextColor(SH110X_WHITE);display.setTextSize(1);display.setCursor(0,0);display.print(flappyScore);
  display.display();
}

