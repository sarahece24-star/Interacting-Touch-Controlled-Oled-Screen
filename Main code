void runGame() {
  if (millis() - lastGameTick < GAME_TICK) return;
  lastGameTick = millis();

  // Jump input (UP or SELECT)
  if ((buttonDown(BTN_UP) || buttonDown(BTN_SELECT)) && dinoOnGround) {
    dinoVY = JUMP_FORCE;
    dinoOnGround = false;
    lastDebounce = millis();
  }

  // Physics
  dinoY += dinoVY;

  if (!dinoOnGround) {
  dinoVY += GRAVITY;
  }

  if (dinoY >= GROUND_Y - DINO_H) {
    dinoY        = GROUND_Y - DINO_H;
    dinoVY       = 0;
    dinoOnGround = true;
  }

  // Move cactuses
  for (int i = 0; i < 2; i++) {
    cactusX[i] -= gameSpeed;
    if (cactusX[i] + cactusW[i] < 0) {
      resetCactus(i);
      gameScore++;
      // Speed up every 5 points
      if (gameScore % 5 == 0 && gameSpeed < 6) gameSpeed++;
    }
    if (checkCollision(i)) {
      gameOver = true;
      showGameOver();
      return;
    }
  }

  // Leg animation
  if (dinoOnGround && millis() - lastLegToggle > LEG_TOGGLE_DELAY) {
    dinoLegToggle = !dinoLegToggle;
    lastLegToggle = millis();
  }

  // Draw frame
  display.clearDisplay();
  display.drawLine(0, GROUND_Y, 128, GROUND_Y, SH110X_WHITE);

  // Score top right
  display.setTextColor(SH110X_WHITE);
  display.setTextSize(1);
  display.setCursor(80, 2);
  display.print("SC:");
  display.print(gameScore);

  drawDino(dinoY, dinoOnGround ? dinoLegToggle : false);

  for (int i = 0; i < 2; i++) {
    if (cactusX[i] < 128) {
      drawCactus(cactusX[i], cactusH[i], cactusW[i]);
    }
  }

  display.display();
}
