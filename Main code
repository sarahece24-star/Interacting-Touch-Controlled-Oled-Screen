void showTimer() {
  display.clearDisplay();

  // Title bar
  display.fillRect(0, 0, 128, 14, SH110X_WHITE);
  display.setTextColor(SH110X_BLACK);
  display.setTextSize(1);
  display.setCursor(44, 3);
  display.print("TIMER");

  if (timerDone) {
    // Flashing DONE screen
    display.setTextColor(SH110X_WHITE);
    display.setTextSize(2);
    display.setCursor(30, 22);
    display.print("DONE!");
    display.setTextSize(1);
    display.setCursor(10, 46);
    display.print("SELECT = restart");
    display.setCursor(10, 56);
    display.print("WAKE   = menu");
  } else {
    // Big countdown digits
    int mins = timerSecondsLeft / 60;
    int secs = timerSecondsLeft % 60;
    display.setTextColor(SH110X_WHITE);
    display.setTextSize(3);
    display.setCursor(18, 18);
    if (mins < 10) display.print("0");
    display.print(mins);
    display.print(":");
    if (secs < 10) display.print("0");
    display.print(secs);

    // Status bar at bottom
    display.setTextSize(1);
    display.setCursor(0, 54);
    if (timerPaused) {
      display.print("UP=+1m SEL=resume");
    } else {
      display.print("UP=+1m SEL=pause ");
    }
  }

  display.display();
}

void initTimer() {
  timerSecondsLeft  = timerTotalSeconds;
  timerRunning      = false;
  timerPaused       = false;
  timerDone         = false;
  timerStartMillis  = millis();
}

void goToOption(int index) {
  switch (index) {
    case 0:
      currentState = STATE_GAME;
      initGame();
      gameStarted = true;
    break;
    case 1:
      currentState = STATE_TIMER;
      initTimer();
      timerRunning = true;
      showTimer();
      break;
    case 2:
      currentState = STATE_CAT;
      catFrame = 0;
      lastFrameTime = millis();
      showCat();
      break;
  }
}

void setup() {
  pinMode(BTN_WAKE,   INPUT_PULLUP);
  pinMode(BTN_UP,     INPUT_PULLUP);
  pinMode(BTN_DOWN,   INPUT_PULLUP);
  pinMode(BTN_SELECT, INPUT_PULLUP);

  display.begin(0x3C, true);

  display.clearDisplay();
  display.display();

  currentState = STATE_CAT;
  showCat();
}

void loop() {

  if (!screenOn && buttonPressed(BTN_WAKE)) {
    screenOn = true;
    currentState = STATE_CAT;
    catFrame = 0;
    lastFrameTime = millis();
    showCat();
  }

  if (!screenOn) return;

  // ── CAT STATE ──
  if (currentState == STATE_CAT) {
    if (millis() - lastFrameTime > FRAME_DELAY) {
      catFrame = 1 - catFrame;
      lastFrameTime = millis();
      showCat();
    }
    if (buttonPressed(BTN_SELECT)) {
      currentState = STATE_MENU;
      selectedIndex = 0;
      showMenu();
    }
    if (buttonPressed(BTN_WAKE)) {
      screenOn = false;
      display.clearDisplay();
      display.display();
    }
  }

  // ── MENU STATE ──
  else if (currentState == STATE_MENU) {
    if (buttonPressed(BTN_UP)) {
      selectedIndex = (selectedIndex - 1 + menuCount) % menuCount;
      showMenu();
    }
    if (buttonPressed(BTN_DOWN)) {
      selectedIndex = (selectedIndex + 1) % menuCount;
      showMenu();
    }
    if (buttonPressed(BTN_SELECT)) {
      goToOption(selectedIndex);
    }
    if (buttonPressed(BTN_WAKE)) {
      currentState = STATE_CAT;
      catFrame = 0;
      lastFrameTime = millis();
      showCat();
    }
  }

  // ── GAME STATE ──
  else if (currentState == STATE_GAME) {
    if (!gameStarted) {
      // Wait for SELECT to start
      if (buttonPressed(BTN_SELECT)) {
        gameStarted = true;
        lastDebounce = millis() + 300;
      }
      if (buttonPressed(BTN_WAKE)) {
        currentState = STATE_MENU;
        selectedIndex = 0;
        showMenu();
      }
    } else if (gameOver) {
      if (buttonPressed(BTN_SELECT)) {
        initGame();
        gameStarted = true;
        lastDebounce = millis() + 300;
      }
      if (buttonPressed(BTN_WAKE)) {
        currentState = STATE_MENU;
        selectedIndex = 0;
        showMenu();
      }
    } else {
      runGame();
      if (buttonPressed(BTN_WAKE)) {
        currentState = STATE_MENU;
        selectedIndex = 0;
        showMenu();
      }
    }
  }

  // ── TIMER STATE ──
  else if (currentState == STATE_TIMER) {

    // Countdown tick
    if (timerRunning && !timerPaused && !timerDone) {
      int elapsed = (millis() - timerStartMillis) / 1000;
      int newSecondsLeft = timerTotalSeconds - elapsed;
      if (newSecondsLeft <= 0) {
        timerSecondsLeft = 0;
        timerDone = true;
        timerRunning = false;
        showTimer();
      } else if (newSecondsLeft != timerSecondsLeft) {
        timerSecondsLeft = newSecondsLeft;
        showTimer();
      }
    }

    // SELECT — pause / resume / restart when done
    if (buttonPressed(BTN_SELECT)) {
      if (timerDone) {
        initTimer();
        timerRunning = true;
        showTimer();
      } else if (timerPaused) {
        // Resume — shift start time forward by paused duration
        timerStartMillis += millis() - timerPausedMillis;
        timerPaused = false;
        showTimer();
      } else {
        timerPausedMillis = millis();
        timerPaused = true;
        showTimer();
      }
    }

    // UP — add 1 minute (works while paused or running)
    if (buttonPressed(BTN_UP)) {
      timerTotalSeconds += 60;
      if (!timerPaused) {
        // Recalculate so added time is reflected immediately
        int elapsed = (millis() - timerStartMillis) / 1000;
        timerSecondsLeft = timerTotalSeconds - elapsed;
      } else {
        timerSecondsLeft += 60;
      }
      showTimer();
    }

    // DOWN — subtract 1 minute (minimum 1 minute)
    if (buttonPressed(BTN_DOWN)) {
      if (timerTotalSeconds > 60) {
        timerTotalSeconds -= 60;
        if (!timerPaused) {
          int elapsed = (millis() - timerStartMillis) / 1000;
          timerSecondsLeft = timerTotalSeconds - elapsed;
          if (timerSecondsLeft < 1) timerSecondsLeft = 1;
        } else {
          timerSecondsLeft -= 60;
          if (timerSecondsLeft < 1) timerSecondsLeft = 1;
        }
        showTimer();
      }
    }

    // WAKE — back to menu, reset timer to default
    if (buttonPressed(BTN_WAKE)) {
      timerTotalSeconds = 120;
      currentState = STATE_MENU;
      selectedIndex = 0;
      showMenu();
    }
  }
}
